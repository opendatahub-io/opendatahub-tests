# =============================================================================
# Pipelines Components smoke test configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is loaded automatically and is in .gitignore.
# Environment variables set in the shell take precedence over .env values.
# =============================================================================

# Pipeline YAMLs — local path or URL to compiled KFP pipeline definitions (required)
# URLs (https://...) are downloaded automatically at test startup.
# AutoML source: https://github.com/red-hat-data-services/pipelines-components
# AutoRAG source: https://github.com/red-hat-data-services/red-hat-ai-examples
AUTOML_PIPELINE_YAML=
AUTORAG_PIPELINE_YAML=

# Pre-existing DSPA connection for AutoRAG (required)
AUTORAG_DSPA_NAMESPACE=
AUTORAG_DSPA_NAME=dspa

# S3 data locations for AutoRAG (required — data must be pre-loaded)
AUTORAG_S3_SECRET_NAME=
AUTORAG_S3_BUCKET=
AUTORAG_INPUT_DATA_KEY=
AUTORAG_TEST_DATA_KEY=

# Models to deploy for AutoRAG (required — test deploys vLLM serving runtimes)
AUTORAG_INFERENCE_MODEL_URI=
# Name passed to vLLM as --served-model-name; also used for INFERENCE_PROVIDER_MODEL_ID
AUTORAG_INFERENCE_MODEL_NAME=
AUTORAG_EMBEDDING_MODEL_URI=
AUTORAG_EMBEDDING_MODEL_NAME=

# LlamaStack catalog-compatible model ID for the inference model (optional).
# The rh-dev LlamaStack distribution validates INFERENCE_MODEL against its model catalog.
# Only set this when AUTORAG_INFERENCE_MODEL_NAME is NOT a supported catalog model
# (e.g. Qwen2.5-0.5B-Instruct).  Use a name like meta-llama/Llama-3.2-1B-Instruct.
# LlamaStack registers the catalog model but routes inference via AUTORAG_INFERENCE_MODEL_NAME.
#AUTORAG_LLAMA_STACK_INFERENCE_MODEL_ID=meta-llama/Llama-3.2-1B-Instruct

# Pipeline tuning (optional — defaults shown)
#AUTORAG_MAX_RAG_PATTERNS=1
#AUTORAG_OPTIMIZATION_METRIC=faithfulness
#AUTORAG_PIPELINE_TIMEOUT=3600
